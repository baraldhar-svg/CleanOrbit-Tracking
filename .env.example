# Database connection URL (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/dbname"

# Server configuration
PORT=8080
SESSION_SECRET="your_very_secret_jwt_session_key_here"
LOG_LEVEL="info"

# Security & Features
QR_TOKEN_SECRET="your_very_secret_qr_token_key_here"
DELAY_THRESHOLD_MINUTES=15
PROXIMITY_ETA_THRESHOLD=5

# Frontend configuration (only needed if deployed separately or in dev without local proxy)
VITE_API_URL="http://localhost:8080"
EXPO_PUBLIC_DOMAIN="localhost"
